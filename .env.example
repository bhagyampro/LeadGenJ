# Database
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@REGION.pooler.supabase.com:5432/postgres"

# NextAuth
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
# Also supported for Auth.js style deployments:
# AUTH_GOOGLE_ID="your-google-oauth-client-id"
# AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/linkedin/callback"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"
OPENROUTER_API_KEY="sk-or-your-openrouter-api-key"
OPENROUTER_MODEL="deepseek/deepseek-v4-flash:free"
OPENROUTER_APP_URL="http://localhost:3000"
OPENROUTER_APP_NAME="LeadgenJ"
AI_PROVIDER="openrouter"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:1b"

# Stripe
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# Resend
RESEND_API_KEY="re_your-resend-api-key"

# Redis
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL="https://your-upstash-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Campaign engine
# "manual" records and blocks due LinkedIn sends until an approved sending provider is connected.
# "demo" marks due actions sent for local/demo testing only.
LINKEDIN_ACTION_PROVIDER="manual"
CRON_SECRET="change-this-secret-for-vercel-cron"

# Application
APP_URL="http://localhost:3000"
NODE_ENV="development"

